LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=LFM2.5-8B-A1B
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

SEARXNG_URL=http://localhost:8888

# Set -1 to disable each operational limit.
# Security policies are never disabled.
AGENT_MAX_STEPS=30
AGENT_COMMAND_TIMEOUT=30
AGENT_MAX_RUNTIME_SECONDS=600
AGENT_MAX_SEARCHES=5
AGENT_MAX_REPEATED_ERRORS=3
AGENT_MAX_CONSECUTIVE_FAILURES=5

# Set -1 to disable sandbox resource limits where applicable.
# Security isolation is never disabled.
SANDBOX_MEMORY_LIMIT=1g
SANDBOX_CPU_LIMIT=1
SANDBOX_PIDS_LIMIT=128

# Git behavior
GIT_AUTO_COMMIT=true
GIT_REQUIRE_DIFF_BEFORE_COMMIT=true
GIT_COMMIT_AFTER_CONFIRMED_OUTPUT=true

# Docker image used for command execution.
SANDBOX_DOCKER_IMAGE=python:3.11-slim
